# ═══════════════════════════════════════════════════════════════
# PEAK — Environment Configuration
# Copy this file to .env and update values for your environment
# ═══════════════════════════════════════════════════════════════

# ── Flask ──
FLASK_SECRET_KEY=change-me-to-a-random-secret-string
FLASK_ENV=production

# ── AI Backend (Ollama) ──
# Point to your Ollama instance (local or VPN-accessible)
OPENAI_API_BASE=http://localhost:11434/v1
CAI_MODEL=llama3.2

# ── ZAP Integration ──
ZAP_API_KEY=your-zap-api-key-here
ZAP_API_URL=http://127.0.0.1:8080

# ── Burp Suite Integration ──
BURP_API_URL=http://127.0.0.1:9090

# ── Database ──
# SQLite database path (auto-created on first run)
PEAK_DB_PATH=data/peak.db



